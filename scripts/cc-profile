#!/usr/bin/env bash
set -euo pipefail

# Resolve symlink so ROOT_DIR works even when running via ~/.local/bin/cc-profile
resolve_script_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="${dir}/${src}"
  done
  cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd
}

SCRIPT_DIR="$(resolve_script_path)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLAUDE_DIR="${HOME}/.claude"
TARGET="${CLAUDE_DIR}/settings.json"
BACKUP_DIR="${CLAUDE_DIR}/backups"

usage() {
  cat <<'USAGE'
Usage:
  cc-profile local
  cc-profile cloud
  cc-profile apply <path-to-profile-json>

Effect:
- Overwrites ~/.claude/settings.json with selected profile JSON
- Creates backup under ~/.claude/backups/
- Prints reminder to reload VS Code window
USAGE
}

ensure_dirs() {
  mkdir -p "${CLAUDE_DIR}" "${BACKUP_DIR}"
}

backup_if_exists() {
  if [[ -f "${TARGET}" ]]; then
    ts="$(date +"%Y%m%d-%H%M%S")"
    cp "${TARGET}" "${BACKUP_DIR}/settings.json.${ts}.bak"
  fi
}

apply_profile_file() {
  local src="$1"
  if [[ ! -f "${src}" ]]; then
    echo "ERROR: profile not found: ${src}" >&2
    exit 1
  fi

  ensure_dirs
  backup_if_exists
  cp "${src}" "${TARGET}"

  echo "✅ settings.json actualizado -> ${TARGET}"
  echo "🔁 Ahora en VS Code corre: Developer: Reload Window (Cmd+Shift+P)"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  local)
    apply_profile_file "${ROOT_DIR}/profiles/claude.local.ollama.json"
    ;;
  cloud)
    apply_profile_file "${ROOT_DIR}/profiles/claude.cloud.zai.json"
    ;;
  apply)
    if [[ -z "${1:-}" ]]; then
      echo "ERROR: missing path-to-profile-json" >&2
      usage
      exit 1
    fi
    apply_profile_file "$1"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    echo "ERROR: unknown command: ${cmd}" >&2
    usage
    exit 1
    ;;
esac
