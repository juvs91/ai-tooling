#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
SETTINGS="${CLAUDE_DIR}/settings.json"
BACKUP="${CLAUDE_DIR}/settings.proxy.json"

mkdir -p "${CLAUDE_DIR}"

if [[ -f "${SETTINGS}" ]]; then
  mv "${SETTINGS}" "${BACKUP}"
  echo "[cc-proxy-off] disabled proxy: moved ${SETTINGS} -> ${BACKUP}"
elif [[ -f "${BACKUP}" ]]; then
  echo "[cc-proxy-off] proxy already disabled (found ${BACKUP}, no ${SETTINGS})"
else
  echo "[cc-proxy-off] nothing to do (no ${SETTINGS} or ${BACKUP})"
fi

echo "[cc-proxy-off] done. Restart VS Code / new terminal session to apply."
