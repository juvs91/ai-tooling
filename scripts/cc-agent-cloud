#!/usr/bin/env bash
set -euo pipefail

# --- ai-tooling: symlink-safe repo root discovery ---
resolve_self() {
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$1" <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
    return 0
  fi
  local p="$1"
  while [ -L "$p" ]; do
    local next
    next="$(readlink "$p")"
    case "$next" in
      /*) p="$next" ;;
      *) p="$(cd "$(dirname "$p")" && pwd)/$next" ;;
    esac
  done
  echo "$p"
}

SELF="$(resolve_self "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/_cc-lib.sh"
ROOT_DIR="$(cc_repo_dir)"
# -----------------------------------------------

PLAN_FILE="${PLAN_FILE:-ai-notes/AI_PLAN.md}"

if [[ ! -f "$PLAN_FILE" ]]; then
  echo "[guardrail] BLOCKED: missing $PLAN_FILE" >&2
  exit 2
fi

# Accept either:
#   STATUS: REVIEWED
# or:
#   REVIEWED: YES
if ! grep -qE '^(STATUS:\s*REVIEWED\b|REVIEWED:\s*YES\s*)$' "$PLAN_FILE"; then
  echo "[guardrail] BLOCKED: plan not reviewed (expected STATUS: REVIEWED or REVIEWED: YES in $PLAN_FILE)" >&2
  exit 3
fi

if ! grep -qE '^Reviewed-by:\s*\S+' "$PLAN_FILE"; then
  echo "[guardrail] BLOCKED: missing reviewer name (Reviewed-by: ...)" >&2
  exit 4
fi

# Aquí irían envs del proxy cloud (ej. :8083) cuando lo habilites
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-http://127.0.0.1:8083}"
export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-dummy}"
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"

exec claude
