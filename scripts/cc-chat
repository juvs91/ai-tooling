#!/usr/bin/env bash
set -euo pipefail

# --- ai-tooling: symlink-safe repo root discovery ---
resolve_self() {
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$1" <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
    return 0
  fi
  local p="$1"
  while [ -L "$p" ]; do
    local next
    next="$(readlink "$p")"
    case "$next" in
      /*) p="$next" ;;
      *) p="$(cd "$(dirname "$p")" && pwd)/$next" ;;
    esac
  done
  echo "$p"
}

SELF="$(resolve_self "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/_cc-lib.sh"
ROOT_DIR="$(cc_repo_dir)"
# -----------------------------------------------

# Parse --cloud flag
USE_CLOUD=false
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --cloud)
      USE_CLOUD=true
      shift
      ;;
    -h|--help)
      echo "Usage: cc-chat [--cloud] [prompt]"
      echo ""
      echo "Options:"
      echo "  --cloud   Use cloud API directly (bypass local proxy)"
      echo ""
      echo "Examples:"
      echo "  cc-chat 'explain this code'           # Uses local proxy"
      echo "  cc-chat --cloud 'explain this code'   # Uses cloud API"
      echo "  echo 'code' | cc-chat 'analyze'       # Pipe content"
      exit 0
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

set -- "${POSITIONAL_ARGS[@]}"

# Configure API endpoint based on --cloud flag
if $USE_CLOUD; then
  # Cloud mode: use Anthropic API directly
  unset ANTHROPIC_BASE_URL
  export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:?ERROR: ANTHROPIC_API_KEY required for --cloud mode}"
  MODEL="${CC_CLOUD_MODEL:-claude-sonnet-4-20250514}"
else
  # Local mode: use proxy
  export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-http://127.0.0.1:8082}"
  export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-dummy}"
  export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"
  MODEL="${CC_MODEL:-claude-haiku-4-5-20251001}"
fi

SYSTEM="${CC_SYSTEM_PROMPT:-Eres un asistente local. Responde directo y breve. No llames herramientas. Si falta información, pide 1-3 preguntas máximo.}"

# Read stdin if piped
STDIN_CONTENT=""
if [ ! -t 0 ]; then
  STDIN_CONTENT="$(cat)"
fi

if [[ $# -gt 0 ]]; then
  # single-shot
  PROMPT="$*"
  if [[ -n "$STDIN_CONTENT" ]]; then
    PROMPT="${PROMPT}

--- INPUT (stdin) ---
${STDIN_CONTENT}"
  fi
  # NOTE: For --print you can pass prompt OR stdin. We'll pass prompt explicitly.
  exec claude -p --model "$MODEL" --tools "" --system-prompt "$SYSTEM" "$PROMPT"
else
  # REPL liviano
  echo "[cc-chat] REPL ligero. Ctrl+C para salir."
  while true; do
    printf "> "
    IFS= read -r line || exit 0
    [[ -z "$line" ]] && continue
    if [[ -n "$STDIN_CONTENT" ]]; then
      line="${line}

--- INPUT (stdin) ---
${STDIN_CONTENT}"
    fi
    claude -p --model "$MODEL" --tools "" --system-prompt "$SYSTEM" "$line"
  done
fi
