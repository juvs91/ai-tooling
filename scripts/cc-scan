#!/usr/bin/env bash
set -euo pipefail

# --- ai-tooling: symlink-safe repo root discovery ---
resolve_self() {
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$1" <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
    return 0
  fi
  local p="$1"
  while [ -L "$p" ]; do
    local next
    next="$(readlink "$p")"
    case "$next" in
      /*) p="$next" ;;
      *) p="$(cd "$(dirname "$p")" && pwd)/$next" ;;
    esac
  done
  echo "$p"
}

SELF="$(resolve_self "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/_cc-lib.sh"
ROOT_DIR="$(cc_repo_dir)"
# -----------------------------------------------

# Parse arguments
USE_CLOUD=""
FILE=""

for arg in "$@"; do
  case "$arg" in
    --cloud)
      USE_CLOUD="--cloud"
      ;;
    -h|--help)
      echo "Usage: cc-scan [--cloud] <path-to-file>"
      echo
      echo "Options:"
      echo "  --cloud   Use cloud API directly (bypass local proxy)"
      echo
      echo "Genera un análisis en ai-notes/<basename>.analysis.md (tools OFF)."
      exit 0
      ;;
    *)
      FILE="$arg"
      ;;
  esac
done

if [[ -z "$FILE" || ! -f "$FILE" ]]; then
  echo "Usage: cc-scan [--cloud] <path-to-file>" >&2
  exit 1
fi

mkdir -p ai-notes
BASENAME="$(basename "$FILE")"
OUT="ai-notes/${BASENAME}.analysis.md"

INSTR=$'Analiza el archivo completo. Solo bullets.\n\n1) Resumen (qué hace)\n2) Entradas/Dependencias (DB, tablas, env vars, endpoints)\n3) Salidas/Efectos (writes, commits, side effects)\n4) Riesgos (bugs, performance, seguridad, datos)\n5) TODO sugeridos (máx 7)\n\nReglas:\n- No inventes.\n- Si falta contexto, dilo.\n- No uses herramientas.\n'

# shellcheck disable=SC2086
cat "$FILE" | cc-chat $USE_CLOUD "$INSTR" > "$OUT"

echo "✅ scan -> $OUT"
