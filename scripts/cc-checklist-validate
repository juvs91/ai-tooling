#!/usr/bin/env bash
set -euo pipefail

# cc-checklist-validate - Valida items del checklist automáticamente
# La IA solo puede marcar [x] si este script pasa
#
# Usage: cc-checklist-validate [--json] [--item NAME]

JSON_OUTPUT=false
SPECIFIC_ITEM=""
PASSED=0
FAILED=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      JSON_OUTPUT=true
      shift
      ;;
    --item)
      SPECIFIC_ITEM="$2"
      shift 2
      ;;
    -h|--help)
      echo "Usage: cc-checklist-validate [--json] [--item NAME]"
      echo ""
      echo "Options:"
      echo "  --json    Output results as JSON"
      echo "  --item    Validate specific item only"
      echo ""
      echo "Examples:"
      echo "  cc-checklist-validate                    # Validate all items"
      echo "  cc-checklist-validate --item 'cc-health' # Validate specific item"
      exit 0
      ;;
    *)
      echo "[cc-checklist-validate] Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Change to repo root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/.."

validate_item() {
  local name="$1"
  local check_cmd="$2"

  # Skip if filtering by specific item
  if [[ -n "$SPECIFIC_ITEM" && "$name" != *"$SPECIFIC_ITEM"* ]]; then
    return 0
  fi

  if eval "$check_cmd" >/dev/null 2>&1; then
    if $JSON_OUTPUT; then
      echo "{\"item\": \"$name\", \"status\": \"pass\"}"
    else
      echo "✅ $name"
    fi
    ((PASSED++)) || true
    return 0
  else
    if $JSON_OUTPUT; then
      echo "{\"item\": \"$name\", \"status\": \"fail\"}"
    else
      echo "❌ $name"
    fi
    ((FAILED++)) || true
    return 1
  fi
}

echo "=== Checklist Validation ==="
echo ""

# ============================================
# CRITICAL ITEMS
# ============================================
echo "--- Critical ---"

validate_item "cc-proxy-init path fix" \
  "grep -q 'cloud-provider-ymls' scripts/cc-proxy-init.sh" || true

validate_item "AI_CONTEXT.example.md exists" \
  "test -f templates/AI_CONTEXT.example.md" || true

validate_item "AI_PLAN.example-detailed.md exists" \
  "test -f templates/AI_PLAN.example-detailed.md" || true

validate_item "AI_LEARNING.template.md exists" \
  "test -f templates/AI_LEARNING.template.md" || true

# ============================================
# IMPORTANT ITEMS
# ============================================
echo ""
echo "--- Important ---"

validate_item "Token counting endpoint" \
  "grep -q 'count_tokens' vendor/claude-code-proxy/server.py" || true

validate_item "Health endpoint" \
  "grep -q '/health' vendor/claude-code-proxy/server.py" || true

validate_item "cc-health script exists" \
  "test -x scripts/cc-health" || true

validate_item "--cloud flag in cc-chat" \
  "grep -q '\-\-cloud' scripts/cc-chat" || true

validate_item "--cloud flag in cc-scan" \
  "grep -q '\-\-cloud' scripts/cc-scan" || true

validate_item "--cloud flag in cc-plan" \
  "grep -q '\-\-cloud' scripts/cc-plan" || true

validate_item "TOOL_ALLOWLIST wildcard support" \
  "grep -q '\"\\*\"' vendor/claude-code-proxy/utils/utils.py" || true

# ============================================
# TESTS
# ============================================
echo ""
echo "--- Tests ---"

validate_item "pytest test_utils.py exists" \
  "test -f vendor/claude-code-proxy/tests/test_utils.py" || true

validate_item "pytest test_server.py exists" \
  "test -f vendor/claude-code-proxy/tests/test_server.py" || true

validate_item "pytest test_router.py exists" \
  "test -f vendor/claude-code-proxy/tests/test_router.py" || true

validate_item "pytest conftest.py exists" \
  "test -f vendor/claude-code-proxy/tests/conftest.py" || true

# ============================================
# DOCUMENTATION
# ============================================
echo ""
echo "--- Documentation ---"

validate_item "CHECKLIST.md exists" \
  "test -f CHECKLIST.md" || true

validate_item "README.md exists" \
  "test -f README.md" || true

# ============================================
# SUMMARY
# ============================================
echo ""
echo "=== Summary ==="
echo "Passed: $PASSED"
echo "Failed: $FAILED"

if [[ $FAILED -eq 0 ]]; then
  echo ""
  echo "All items validated! IA can mark [x] in CHECKLIST.md"
  exit 0
else
  echo ""
  echo "Some items failed. IA must NOT mark [x] until all pass."
  exit 1
fi
