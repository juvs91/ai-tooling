#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cc-proxy-up [path-to-override.yml]

Levanta la unión de servicios definidos en docker-compose.yml + el override.
Si un servicio aparece en ambos, el override tiene precedencia (merge estándar).

Env vars:
  PROFILE_ENV=profile-envs/cloud.groq.env   # env_file extra para todos los servicios
  HOST_SERVER=./vendor/claude-code-proxy/server.py
  CONTAINER_SERVER=/claude-code-proxy/server.py
  ENABLE_RELOAD=1|0  (default 1)
  BIND_PORT=8083     # si se setea, fuerza ese puerto en TODOS los servicios (útil para testing)

Examples:
  # Levanta proxy_local (8082) + proxy_cloud (8083) + proxy_cloud_school (8084)
  cc-proxy-up cloud-provider-ymls/docker-compose.zai-school.override.yml

  # Levanta proxy_local (8082) + proxy_cloud (8083, con cloud.zai.env)
  cc-proxy-up cloud-provider-ymls/docker-compose.zai.override.yml

  # Override explícito de puerto (single-service, para testing)
  BIND_PORT=8090 cc-proxy-up cloud-provider-ymls/docker-compose.zai.override.yml
USAGE
}

resolve_self() {
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$1" <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
    return 0
  fi
  local p="$1"
  while [ -L "$p" ]; do
    local next
    next="$(readlink "$p")"
    case "$next" in
      /*) p="$next" ;;
      *) p="$(cd "$(dirname "$p")" && pwd)/$next" ;;
    esac
  done
  echo "$p"
}

SELF="$(resolve_self "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/_cc-lib.sh"
ROOT_DIR="$(cc_repo_dir)"
cd "$ROOT_DIR"

OVERRIDE="${1:-docker-compose.cloud.override.yml}"
case "${OVERRIDE}" in
  -h|--help) usage; exit 0;;
esac

if [[ ! -f docker-compose.yml ]]; then
  echo "ERROR: missing docker-compose.yml" >&2
  exit 2
fi
if [[ ! -f "$OVERRIDE" ]]; then
  echo "ERROR: override file not found: $OVERRIDE" >&2
  exit 2
fi

HOST_SERVER="${HOST_SERVER:-./vendor/claude-code-proxy/server.py}"
CONTAINER_SERVER="${CONTAINER_SERVER:-/claude-code-proxy/server.py}"
BIND_PORT_EXPLICIT="${BIND_PORT:-}"   # vacío si el usuario no lo seteó
BIND_PORT="${BIND_PORT:-8083}"

if [[ ! -f "$HOST_SERVER" ]]; then
  echo "ERROR: HOST_SERVER not found: $HOST_SERVER" >&2
  exit 2
fi

# ✅ 1. obtener servicios PRIMERO (unión de base + override)
services=$(parse_compose_services "docker-compose.yml" "$OVERRIDE")

if [[ -z "$services" ]]; then
  echo "ERROR: No services found in $OVERRIDE" >&2
  exit 2
fi

# ✅ 2. generar override dinámico correctamente
TMP_OVERRIDE="$(mktemp -t cc-proxy-dev-override.XXXXXX.yml)"
trap 'rm -f "$TMP_OVERRIDE"' EXIT

{
  echo "services:"
  for service in $services; do
    echo "  $service:"

    # Venv aislado por servicio → evita race condition cuando varios comparten el bind mount
    echo "    environment:"
    echo "      - UV_PROJECT_ENVIRONMENT=/claude-code-proxy/.venv-${service}"

    echo "    env_file:"
    echo "      - ./.env"

    if [[ -n "${PROFILE_ENV:-}" ]]; then
      echo "      - ${PROFILE_ENV}"
    fi

    echo "    volumes:"
    echo "      - ./vendor/claude-code-proxy:/claude-code-proxy"

    if [[ -n "$BIND_PORT_EXPLICIT" ]]; then
      echo "    ports:"
      echo "      - \"${BIND_PORT}:8082\""
    fi
  done
} > "$TMP_OVERRIDE"

echo "Using override: $OVERRIDE"
echo "Services: $services"
echo "Mount: $HOST_SERVER -> $CONTAINER_SERVER"
if [[ -n "$BIND_PORT_EXPLICIT" ]]; then
  echo "Port: $BIND_PORT -> 8082 (forced)"
else
  echo "Port: from compose YAMLs (no override)"
fi

# ✅ 3. levantar servicios correctamente
for service in $services; do
  echo "[+] Recreating service: $service"
  docker compose \
    -f docker-compose.yml \
    -f "$OVERRIDE" \
    -f "$TMP_OVERRIDE" \
    up -d --force-recreate "$service"
done

docker ps --format "table {{.Names}}\t{{.Ports}}"