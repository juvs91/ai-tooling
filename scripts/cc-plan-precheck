#!/usr/bin/env bash
set -euo pipefail

# cc-plan-precheck - Sugiere mejoras al plan (NO bloquea)
# El humano decide si acepta las sugerencias
#
# Usage: cc-plan-precheck [path-to-plan]

PLAN="${1:-ai-notes/AI_PLAN.md}"

if [[ ! -f "$PLAN" ]]; then
  echo "[cc-plan-precheck] ERROR: Plan not found: $PLAN" >&2
  echo "Usage: cc-plan-precheck [path-to-plan]" >&2
  exit 1
fi

echo "=== Pre-check: $PLAN ==="
echo ""

warnings=0
suggestions=()

# ============================================
# CHECK 1: STATUS
# ============================================
if grep -qE '^STATUS:\s*DRAFT' "$PLAN"; then
  echo "Status: DRAFT (pendiente de review)"
elif grep -qE '^STATUS:\s*REVIEWED' "$PLAN"; then
  echo "Status: REVIEWED (listo para ejecucion)"
else
  suggestions+=("Agregar STATUS: DRAFT o STATUS: REVIEWED al inicio")
  ((warnings++))
fi

# ============================================
# CHECK 2: Reviewed-by
# ============================================
if grep -qE '^Reviewed-by:\s*<' "$PLAN"; then
  suggestions+=("Reviewed-by aun tiene placeholder <pendiente>")
  ((warnings++))
elif grep -qE '^Reviewed-by:\s*\S+' "$PLAN"; then
  reviewer=$(grep -oE '^Reviewed-by:\s*\S+' "$PLAN" | cut -d: -f2 | tr -d ' ')
  echo "Reviewer: $reviewer"
else
  suggestions+=("Agregar Reviewed-by: <nombre> antes de ejecutar")
  ((warnings++))
fi

echo ""

# ============================================
# CHECK 3: Pasos numerados
# ============================================
if grep -qE '^[0-9]+[\)\.]' "$PLAN"; then
  step_count=$(grep -cE '^[0-9]+[\)\.]' "$PLAN" || echo 0)
  echo "Pasos numerados: $step_count encontrados"
else
  suggestions+=("Agregar pasos numerados (1), 2), etc.) para claridad")
  ((warnings++))
fi

# ============================================
# CHECK 4: Comandos exactos
# ============================================
if grep -qE '```(bash|sh|shell)' "$PLAN"; then
  code_blocks=$(grep -c '```' "$PLAN" || echo 0)
  echo "Bloques de codigo: $((code_blocks / 2)) encontrados"
else
  suggestions+=("Agregar bloques de codigo con comandos exactos")
  ((warnings++))
fi

# ============================================
# CHECK 5: Validaciones por paso
# ============================================
if grep -qiE 'validaci[oó]n|verificar|test|check|expect' "$PLAN"; then
  echo "Validaciones: encontradas"
else
  suggestions+=("Agregar validaciones por paso (como verificar que funciono)")
  ((warnings++))
fi

# ============================================
# CHECK 6: MISSING_INFO resuelto
# ============================================
if grep -q '## MISSING_INFO' "$PLAN"; then
  missing_content=$(sed -n '/## MISSING_INFO/,/^## /p' "$PLAN" | grep -v '^## ' | grep -v '^$' | head -3)
  if [[ -n "$missing_content" ]]; then
    suggestions+=("Resolver ## MISSING_INFO antes de marcar REVIEWED:")
    suggestions+=("  $missing_content")
    ((warnings++))
  fi
fi

# ============================================
# CHECK 7: Riesgos documentados
# ============================================
if grep -qiE '## riesgos|## risks' "$PLAN"; then
  echo "Riesgos: seccion encontrada"
else
  suggestions+=("Considerar agregar seccion ## Riesgos")
  ((warnings++))
fi

# ============================================
# CHECK 8: Checklist de validacion
# ============================================
if grep -qE '## checklist|## validaci[oó]n final' "$PLAN"; then
  echo "Checklist: seccion encontrada"
else
  suggestions+=("Considerar agregar ## Checklist de validacion final")
  ((warnings++))
fi

# ============================================
# SUMMARY
# ============================================
echo ""
echo "=== Resultado ==="

if [[ $warnings -eq 0 ]]; then
  echo ""
  echo "Plan listo para revision humana"
  echo ""
  echo "Siguiente paso:"
  echo "  1. Revisar manualmente el plan"
  echo "  2. Cambiar STATUS: DRAFT -> STATUS: REVIEWED"
  echo "  3. Agregar Reviewed-by: <tu-nombre>"
  echo "  4. Ejecutar: cc-agent-cloud"
else
  echo ""
  echo "$warnings sugerencias de mejora (OPCIONALES - tu decides):"
  echo ""
  for suggestion in "${suggestions[@]}"; do
    echo "  $suggestion"
  done
  echo ""
  echo "NOTA: Estas son sugerencias, NO bloquean."
  echo "El humano tiene la ultima palabra sobre si el plan esta listo."
fi

# Siempre exit 0 porque es sugerencia, no bloqueo
exit 0
