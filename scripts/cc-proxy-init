#!/usr/bin/env bash
set -euo pipefail

PROFILE="${1:-zai}"   # zai|groq|gemini|ollama
BASE="docker-compose.yml"
OVR="docker-compose.${PROFILE}.override.yml"
ENVF=".env.${PROFILE}"

case "${PROFILE}" in
  zai)
    cat > "${ENVF}" <<'ENV'
# Z.AI
ZAI_API_KEY=
ENV

    cat > "${OVR}" <<'YAML'
services:
  cloud:
    env_file:
      - .env
      - .env.zai
    environment:
      OPENAI_BASE_URL: "https://api.z.ai/api/paas/v4/"
      OPENAI_API_KEY: "${ZAI_API_KEY}"
      PREFERRED_PROVIDER: "openai"

      # Ajusta a tu modelo real de Z.AI
      SMALL_MODEL: "glm-4.7"
      BIG_MODEL: "glm-4.7"
      BUILDING_MODEL: "glm-4.7"

      TOOL_ALLOWLIST: ""
      POLICY_NOTE_IN_SYSTEM: "1"
YAML
    ;;
  groq)
    cat > "${ENVF}" <<'ENV'
# Groq
GROQ_API_KEY=
ENV

    cat > "${OVR}" <<'YAML'
services:
  cloud:
    env_file:
      - .env
      - .env.groq
    environment:
      OPENAI_BASE_URL: "https://api.groq.com/openai/v1"
      OPENAI_API_KEY: "${GROQ_API_KEY}"
      PREFERRED_PROVIDER: "openai"

      # ejemplo
      SMALL_MODEL: "llama-3.1-8b-instant"
      BIG_MODEL: "llama-3.1-70b-versatile"
      BUILDING_MODEL: "llama-3.1-70b-versatile"
YAML
    ;;
  gemini)
    cat > "${ENVF}" <<'ENV'
# Gemini (API key)
GEMINI_API_KEY=
ENV

    cat > "${OVR}" <<'YAML'
services:
  cloud:
    env_file:
      - .env
      - .env.gemini
    environment:
      PREFERRED_PROVIDER: "google"
      # tu server ya usa GEMINI_API_KEY desde env
      GEMINI_API_KEY: "${GEMINI_API_KEY}"
      SMALL_MODEL: "gemini-2.5-flash"
      BIG_MODEL: "gemini-2.5-pro"
      BUILDING_MODEL: "gemini-2.5-pro"
YAML
    ;;
  ollama)
    cat > "${ENVF}" <<'ENV'
# Ollama (no key)
ENV

    cat > "${OVR}" <<'YAML'
services:
  cloud:
    env_file:
      - .env
      - .env.ollama
    environment:
      OPENAI_BASE_URL: "http://host.docker.internal:11434/v1"
      PREFERRED_PROVIDER: "openai"
      SMALL_MODEL: "cc-local:chat"
      BIG_MODEL: "cc-local:big"
      BUILDING_MODEL: "cc-local:build"
YAML
    ;;
  *)
    echo "[cc-proxy-init] unknown profile: ${PROFILE}" >&2
    exit 2
    ;;
esac

echo "[cc-proxy-init] wrote ${ENVF}"
echo "[cc-proxy-init] wrote ${OVR}"
echo
echo "Next:"
echo "  1) Fill the key in ${ENVF}"
echo "  2) ./cc-proxy-up ${PROFILE}"
