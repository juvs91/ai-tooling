# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env to git
# ============================================================

# Tool Configuration
TOOL_ALLOWLIST=""
POLICY_NOTE_IN_SYSTEM=1
MAX_INPUT_TOKENS=30000
HARD_BLOCK_OVERSIZE=0

HOST_SERVER=./vendor/claude-code-proxy/server.py
CONTAINER_SERVER=/claude-code-proxy/server.py

# Web Search (Serper)
SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE

# Atlassian Configuration
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
ATLASSIAN_USERNAME=your.email@example.com
ATLASSIAN_CONFLUENCE_TOKEN=YOUR_CONFLUENCE_TOKEN_HERE
ATLASSIAN_JIRA_API_TOKEN=YOUR_JIRA_TOKEN_HERE
ATLASSIAN_BITBUCKET_API_TOKEN=YOUR_BITBUCKET_TOKEN_HERE
BITBUCKET_DEFAULT_WORKSPACE=your-workspace

# Database Configuration
ALLOYDB_PASSWORD=YOUR_DB_PASSWORD_HERE

# Squit Search MCP
SQUIT_API_KEY=YOUR_SQUIT_API_KEY_HERE
