{
  "permissions": {
    "allow": [
      "Bash(command -v:*)",
      "Bash(node:*)",
      "Bash(npm --version:*)",
      "Bash(uvx:*)",
      "Bash(pip3:*)",
      "Bash(npm install:*)",
      "Bash(postgres-mcp:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm info:*)",
      "mcp__atlassian__jira_search",
      "mcp__atlassian__jira_get_user_profile",
      "mcp__squit__*",
      "mcp__alloydb__query_tool",
      "Bash(source:*)",
      "Bash(nvm use:*)",
      "mcp__cloudsql__query_tool",
      "Bash(python3:*)",
      "Bash(xargs kill:*)",
      "Bash(for i in 1 2 3 4 5)",
      "Bash(do curl -s http://localhost:8000/health)",
      "Bash(break)",
      "Bash(done)",
      "Bash(xargs:*)"
    ],
    "deny": []
  },
  "project": {
    "name": "AI-Tooling",
    "code": "AITOOL",
    "description": "Proxy Claude→OpenAI con routing multi-proveedor"
  },
  "skills": {
    "workflow-coordinator": {
      "description": "Expert workflow coordinator that detects intent, routes to appropriate workflows, and enforces guard rails",
      "category": "workflow",
      "command": ".agents/skills/workflow/workflow-coordinator/SKILL.md",
      "documentation": ".claude/commands/workflow-coordinator.md"
    },
    "ticket-planner": {
      "description": "Planificación Jira con pre-planning bloat (11 fuentes) y grokking refinement",
      "category": "workflow",
      "command": ".agents/skills/workflow/ticket-planner/SKILL.md",
      "documentation": ".agents/skills/workflow/ticket-planner/SKILL.md"
    },
    "ticket-implementation": {
      "description": "Ejecución 7-hop multihop grounding con verificación iterativa",
      "category": "workflow",
      "command": ".agents/skills/workflow/ticket-implementation/SKILL.md",
      "documentation": ".agents/skills/workflow/ticket-implementation/SKILL.md"
    },
    "jira-context": {
      "description": "Traer contexto de tickets Jira",
      "category": "project",
      "command": "mcp__atlassian__jira_get_issue,mcp__atlassian__jira_search",
      "documentation": ".claude/commands/jira-context.md"
    },
    "sp-search": {
      "description": "Buscar stored procedures legacy",
      "category": "search",
      "command": "mcp__squit__squit_search",
      "documentation": ".claude/commands/sp-search.md"
    },
    "tunnel-health": {
      "description": "Verificar salud del entorno",
      "category": "devops",
      "command": "./scripts/tunnel-health",
      "documentation": ".claude/commands/tunnel-health.md"
    },
    "cascade-analyzer": {
      "description": "Analizar cascada de precios y fletes (AlloyDB MCP)",
      "category": "database",
      "command": "mcp__alloydb__query_tool",
      "documentation": ".claude/commands/cascade-analyzer.md"
    },
    "alloydb-query": {
      "description": "Consultar datos de precios en AlloyDB ODS",
      "category": "database",
      "command": "mcp__alloydb__query_tool",
      "documentation": ".claude/commands/alloydb-query.md"
    },
    "alloydb-debug": {
      "description": "Diagnosticar errores de calculo en AlloyDB",
      "category": "database",
      "command": "mcp__alloydb__query_tool",
      "documentation": ".claude/commands/alloydb-debug.md"
    },
    "cloudsql-query": {
      "description": "Consultar datos de la API de precios en CloudSQL",
      "category": "database",
      "command": "mcp__cloudsql__query_tool",
      "documentation": ".claude/commands/cloudsql-query.md"
    }
  },
  "documentation": {
    "basePath": "docs",
    "sections": {
      "overview": "01-overview/",
      "proxy": "02-proxy/",
      "skills": "03-skills/",
      "scripts": "04-scripts/",
      "mcp": "05-mcp/"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous.sh",
            "timeout": 5
          }
        ],
        "description": "Block destructive params in any tool call (discard_changes, force_delete, etc.)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2",
            "timeout": 5
          }
        ],
        "description": "Block git --no-verify flag to protect pre-commit hooks"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/adr-gate.sh",
            "timeout": 10
          }
        ],
        "description": "ADR Gate: bloquea edits a vendor/ y .agents/ sin ADR staged"
      },
      {
        "matcher": "Workflow|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-isolation-gate.sh",
            "timeout": 5
          }
        ],
        "description": "Worktree isolation gate: advierte parallel(agent()) sin isolation: 'worktree'; redirige Agent→Workflow para paralelismo aislado"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/config-protection.sh",
            "timeout": 10
          }
        ],
        "description": "Config protection: bloquea edits a pyproject.toml (secciones tool.*), ruff.toml, .eslintrc*, .prettierrc*, .pre-commit-config.yaml"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-secrets.sh",
            "timeout": 10
          }
        ],
        "description": "Secret protection: bloquea escritura de API keys, tokens y passwords en archivos trackeados por git"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/quality-enforce.sh",
            "timeout": 5
          }
        ],
        "description": "Quality enforce: bloquea edits a código si hay errores pendientes en .claude/quality-state/ (genérico, any language)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scope-gate.sh",
            "timeout": 5
          }
        ],
        "description": "Scope gate: bloquea edits fuera del scope definido en .claude/task-scope.json"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ts-quality-gate.sh",
            "timeout": 30
          }
        ],
        "description": "TS quality gate: corre tsc tras edits de *.ts/*.tsx, guarda estado para ts-enforce.sh"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/migration-gate.sh",
            "timeout": 10
          }
        ],
        "description": "Migration gate: avisa cuando se edita un modelo SQLAlchemy sin correr alembic revision"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-implementation.sh",
            "timeout": 15
          }
        ],
        "description": "Verify implementation: detecta funciones stub (pass/TODO/NotImplemented) en archivos Python editados"
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/edit-drift-detector.sh",
            "timeout": 5
          }
        ],
        "description": "Drift detector: rastrea edits vs test runs, advierte a 8/15/25 edits sin verificación"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agents/sync_skills.sh 2>/dev/null || true",
            "timeout": 30
          }
        ],
        "description": "Sync agent skills al inicio de cada sesión (throttle 24h)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/intent-bootstrap.sh",
            "timeout": 5
          }
        ],
        "description": "Bootstrap task-scope.json en bash puro (sin Skill tool) — funciona en --print, interactivo y VS Code"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-autoload.sh",
            "timeout": 5
          }
        ],
        "description": "Autoload stateless de workflow-coordinator en cada prompt"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-scope-updater.sh",
            "timeout": 5
          }
        ],
        "description": "Detecta cambios de modo mid-session (analiza→implementa) y actualiza task-scope.json"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/plan-mode-gate.sh",
            "timeout": 5
          }
        ],
        "description": "Inyecta mandato de plan mode una vez por sesión"
      }
    ]
  },
  "connections": {
    "alloydb": {
      "type": "mcp",
      "mcpServer": "alloydb",
      "fallbackMessage": "El tunel SSH no esta activo. Ejecutar: ./scripts/start-ssh-tunnel.sh",
      "fallbackDocs": "docs/alloydb/ssh-tunnel.md"
    },
    "atlassian": {
      "type": "mcp",
      "mcpServer": "atlassian",
      "docs": "https://deacero.atlassian.net/wiki/ARQ"
    }
  },
  "mcpServers": {
    "alloydb": {
      "command": "node",
      "args": [
        "/Users/jeguzman/.nvm/versions/node/v20.20.0/lib/node_modules/postgres-mcp/dist/index.js"
      ],
      "env": {
        "DB_MAIN_URL": "postgresql://postgres:$ALLOYDB_PASSWORD@localhost:5435/ods"
      }
    },
    "atlassian": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "CONFLUENCE_URL": "https://deacero.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "jeguzman@deacero.com",
        "CONFLUENCE_API_TOKEN": "$ATLASSIAN_CONFLUENCE_TOKEN",
        "JIRA_URL": "https://deacero.atlassian.net",
        "JIRA_USERNAME": "jeguzman@deacero.com",
        "JIRA_API_TOKEN": "$ATLASSIAN_JIRA_API_TOKEN"
      }
    },
    "bitbucket": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@aashari/mcp-server-atlassian-bitbucket"],
      "env": {
        "ATLASSIAN_USER_EMAIL": "jeguzman@deacero.com",
        "ATLASSIAN_API_TOKEN": "$ATLASSIAN_BITBUCKET_API_TOKEN",
        "BITBUCKET_DEFAULT_WORKSPACE": "deacero"
      }
    },
    "squit": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://squit-mcp.deacero.us/mcp",
        "--header",
        "X-API-Key:$SQUIT_API_KEY"
      ]
    },
    "cloudsql": {
      "command": "bash",
      "args": ["./scripts/cloudsql-mcp.sh"]
    }
  }
}
