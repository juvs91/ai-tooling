{
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "WebFetch(domain:docs.z.ai)",
      "WebFetch(domain:karim.touma.io)",
      "WebFetch(domain:claudelog.com)",
      "WebFetch(domain:hboon.com)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-secrets.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
