#!/usr/bin/env bash
set -euo pipefail

PORT=11434
LOG="$HOME/.ollama/manual-serve.log"
PIDFILE="$HOME/.ollama/ollama-serve.pid"
OLLAMA_BIN="/opt/homebrew/bin/ollama"

mkdir -p "$HOME/.ollama"

# Evitar doble arranque
if lsof -nP -iTCP:${PORT} -sTCP:LISTEN >/dev/null 2>&1; then
  echo "[ollama-up] ERROR: port ${PORT} already in use"
  lsof -nP -iTCP:${PORT} -sTCP:LISTEN
  exit 1
fi

# Defaults seguros
export OLLAMA_NUM_PARALLEL="${OLLAMA_NUM_PARALLEL:-1}"
export OLLAMA_CONTEXT_LENGTH="${OLLAMA_CONTEXT_LENGTH:-8192}"
export OLLAMA_FLASH_ATTENTION="${OLLAMA_FLASH_ATTENTION:-false}"

echo "[ollama-up] starting ollama serve on 127.0.0.1:${PORT}"
echo "[ollama-up] logs: ${LOG}"

nohup "$OLLAMA_BIN" serve >"$LOG" 2>&1 &
echo $! > "$PIDFILE"

sleep 0.5
lsof -nP -iTCP:${PORT} -sTCP:LISTEN || true
