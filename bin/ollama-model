#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  ollama-model make --base <base> --tag <tag> [--profile chat|planning|building] \
    [--ctx N] [--predict N] [--temp X] [--topk N] [--topp X] [--gpu N] [--force]

  ollama-model show --tag <model:tag>
  ollama-model list
  ollama-model paths

Notes:
- Modelfiles: ~/.ollama/modelfiles/<sanitized_tag>.Modelfile
- SYSTEM files: ~/.ollama/systems/<profile>.txt
USAGE
}

PROFILE_DEFAULT_SYSTEM() {
  local profile="$1"
  case "$profile" in
    chat)
      cat <<'TXT'
Eres un asistente conversacional.
Reglas:
- NO ejecutes comandos.
- NO edites archivos.
- NO sugieras herramientas.
- Responde natural y directo.
Si te preguntan quien eres: "Qwen 2.5 Coder (local via Ollama)".
TXT
      ;;
    planning)
      cat <<'TXT'
Eres un asistente de planificacion tecnica.
Reglas:
- NO ejecutes comandos ni edites archivos.
- Devuelve planes concretos, checklist y riesgos.
- Si falta info, haz 1-3 preguntas maximo.
TXT
      ;;
    building)
      cat <<'TXT'
Eres un asistente de implementacion.
Reglas:
- Cambios minimos y correctos.
- Si hay ambiguedad, propone 2 opciones.
- Si te piden ejecutar/editar, pide confirmacion explicita antes.
TXT
      ;;
    *)
      echo "Unknown profile: $profile" >&2
      exit 1
      ;;
  esac
}

# Simple presets if user doesn't pass flags (tuneables)
apply_presets() {
  local profile="$1"
  case "$profile" in
    chat)
      ctx="${ctx:-16384}"
      predict="${predict:-384}"
      temp="${temp:-0.2}"
      topk="${topk:-40}"
      topp="${topp:-0.9}"
      gpu="${gpu:-0}"
      ;;
    planning)
      ctx="${ctx:-32768}"
      predict="${predict:-900}"
      temp="${temp:-0.15}"
      topk="${topk:-40}"
      topp="${topp:-0.9}"
      gpu="${gpu:-0}"
      ;;
    building)
      ctx="${ctx:-16384}"
      predict="${predict:-900}"
      temp="${temp:-0.1}"
      topk="${topk:-40}"
      topp="${topp:-0.9}"
      gpu="${gpu:-0}"
      ;;
  esac
}

cmd="${1:-}"
shift || true

case "$cmd" in
  make)
    base=""
    tag=""
    profile="chat"
    force="0"

    # Optional overrides (unset means "use preset")
    ctx=""
    predict=""
    temp=""
    topk=""
    topp=""
    gpu=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --base) base="$2"; shift 2;;
        --tag) tag="$2"; shift 2;;
        --profile) profile="$2"; shift 2;;
        --ctx) ctx="$2"; shift 2;;
        --predict) predict="$2"; shift 2;;
        --temp) temp="$2"; shift 2;;
        --topk) topk="$2"; shift 2;;
        --topp) topp="$2"; shift 2;;
        --gpu) gpu="$2"; shift 2;;
        --force) force="1"; shift 1;;
        -h|--help) usage; exit 0;;
        *) echo "Unknown arg: $1" >&2; usage; exit 1;;
      esac
    done

    if [[ -z "$base" || -z "$tag" ]]; then
      echo "ERROR: --base and --tag are required" >&2
      usage
      exit 1
    fi

    apply_presets "$profile"

    mkdir -p "$HOME/.ollama/modelfiles" "$HOME/.ollama/systems"

    sysfile="$HOME/.ollama/systems/${profile}.txt"
    if [[ ! -f "$sysfile" ]]; then
      PROFILE_DEFAULT_SYSTEM "$profile" > "$sysfile"
      echo "[ollama-model] created default SYSTEM file: $sysfile" >&2
    fi

    # sanitize tag for filename
    sanitized="${tag//\//_}"
    sanitized="${sanitized//:/_}"
    sanitized="${sanitized//@/_}"
    modelfile="$HOME/.ollama/modelfiles/${sanitized}.Modelfile"

    if [[ -f "$modelfile" && "$force" != "1" ]]; then
      echo "ERROR: Modelfile exists: $modelfile (use --force to overwrite)" >&2
      exit 1
    fi

    {
      echo "FROM ${base}"
      echo
      echo "PARAMETER num_gpu ${gpu}"
      echo "PARAMETER num_ctx ${ctx}"
      echo "PARAMETER num_predict ${predict}"
      echo "PARAMETER temperature ${temp}"
      echo "PARAMETER top_k ${topk}"
      echo "PARAMETER top_p ${topp}"
      echo
      echo "SYSTEM <<'SYSTEM_EOF'"
      cat "$sysfile"
      echo "SYSTEM_EOF"
    } > "$modelfile"

    echo "[ollama-model] Modelfile -> $modelfile" >&2
    ollama create "$tag" -f "$modelfile"
    echo "[ollama-model] created model: $tag" >&2
    ;;
  show)
    if [[ "${1:-}" != "--tag" || -z "${2:-}" ]]; then
      echo "Usage: ollama-model show --tag <model:tag>" >&2
      exit 1
    fi
    ollama show "$2" | sed -n '1,180p'
    ;;
  list)
    ollama list
    ;;
  paths)
    echo "Modelfiles: $HOME/.ollama/modelfiles"
    echo "SYSTEMs:    $HOME/.ollama/systems"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
